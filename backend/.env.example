# [REQUERIDO] Groq API Key predeterminada para el servidor (Usada si el usuario no tiene la suya propia)
GROQ_API_KEY=gsk_tucodigoaqui

# [OPCIONAL] ElevenLabs API Key predeterminada para el servidor
ELEVENLABS_API_KEY=sk_tucodigoaqui

# [OPCIONAL] Variables para el servicio de mejora de texto con IA
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
AI_REQUEST_TIMEOUT=60000

# Puerto en el que se ejecuta el servidor Backend
PORT=3001

# URL del Frontend permitida (CORS)
FRONTEND_URL=http://localhost:5173

# Límite de subida de archivos de audio
MAX_FILE_SIZE_MB=1024

# Directorios de uso temporal local
TEMP_DIR=./temp
UPLOADS_DIR=./uploads
LOCAL_STORAGE_DIR=./uploads

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=tu_cuenta;AccountKey=tu_clave;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=archivos-temporales
AZURE_STORAGE_TEMP_RETENTION_HOURS=24
AZURE_STORAGE_MAX_FILE_SIZE_MB=1024
